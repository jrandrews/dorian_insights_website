---
import '../styles.css';

interface Props {
  title: string;
  description: string;
  noindex?: boolean;
}

const { title, description, noindex = false } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{title}</title>
<meta name="description" content={description}>
{noindex && <meta name="robots" content="noindex">}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500&family=IBM+Plex+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<link rel="alternate" type="application/rss+xml" title="Dorian Insights" href={new URL('rss.xml', Astro.site)}>
</head>
<body>

<nav>
  <div class="container">
    <div class="brand">
      <span class="brand-mark"></span>
      <a href="/">Dorian Insights</a>
    </div>
    <button class="nav-toggle" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="nav-menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <ul id="nav-menu">
      <li><a href="/#plan">How It Works</a></li>
      <li><a href="/#services">Services</a></li>
      <li><a href="/#engagement">Engagement</a></li>
      <li><a href="/#work">Results</a></li>
      <li><a href="/insights/">Insights</a></li>
      <li><a href="/about/">About</a></li>
      <li class="always"><a class="inquire" href="/#contact">Schedule a Call</a></li>
    </ul>
  </div>
</nav>

<slot />

<footer>
  <div class="container">
    <div>© Dorian Insights, L.L.C.</div>
    <div><a href="https://www.linkedin.com/in/joshuaroyandrews/" target="_blank" rel="noopener">LinkedIn</a> · Making your data and decisions simpler</div>
  </div>
</footer>

<script is:inline>
  const io = new IntersectionObserver(
    (entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          e.target.classList.add('in-view');
          io.unobserve(e.target);
        }
      }
    },
    { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
  );
  document.querySelectorAll('.reveal, .reveal-stagger').forEach((el) => io.observe(el));
</script>

<script is:inline>
  const nav = document.querySelector('nav');
  const navToggle = document.querySelector('.nav-toggle');
  navToggle.addEventListener('click', () => {
    const open = nav.classList.toggle('open');
    navToggle.setAttribute('aria-expanded', String(open));
    navToggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
  });
  nav.querySelectorAll('#nav-menu a').forEach((a) =>
    a.addEventListener('click', () => {
      nav.classList.remove('open');
      navToggle.setAttribute('aria-expanded', 'false');
      navToggle.setAttribute('aria-label', 'Open menu');
    })
  );
</script>

