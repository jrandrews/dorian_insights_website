---
import Base from '../layouts/Base.astro';
---
<Base
  title="Thanks — Dorian Insights"
  description="Your message has been received. Josh will be in touch."
  noindex
>

<header class="hero" id="top">
  <div class="container">
    <span class="eyebrow">Message received</span>
    <h1>You've taken the first step &mdash; <span class="quiet">I'll be in touch.</span></h1>
    <div class="hero-body">
      <div>
        <p class="lede">
          Your message landed. I read every inquiry personally and will reply soon — usually to set up a short call where we'll assess where your analytics stand today. If it's time-sensitive, feel free to follow up at
          <a href="mailto:hello@dorianinsights.com">hello@dorianinsights.com</a>.
        </p>
        <div class="cta-row">
          <a class="btn-primary" href="/">Back to the site <span>→</span></a>
          <a class="btn-secondary" href="https://www.linkedin.com/in/joshuaroyandrews/" target="_blank" rel="noopener">LinkedIn ↗</a>
        </div>
      </div>
    </div>
  </div>
</header>

</Base>
